# Copy this file to .env and fill in real values for local `vercel dev` testing.
# For production, set the same variables via `vercel env add` or the Vercel dashboard.
#
# Gmail setup: SMTP_USER/SMTP_PASS must be a Google Account "App Password"
# (requires 2-Step Verification enabled) — your normal login password will NOT work.
# https://myaccount.google.com/apppasswords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
FROM_EMAIL=you@gmail.com

# Gemini setup: get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# optional, defaults to gemini-2.5-flash if unset
GEMINI_MODEL=gemini-2.5-flash
